@model RestaurantBook.Models.Reserva
@{
    ViewData["Title"] = "Nueva Reserva";
}

<div class="page-header">
    <h1>Nueva Reserva</h1>
    <a asp-action="Index" class="btn btn-secondary">← Volver</a>
</div>

<div class="form-container">
    <form asp-action="Create">
        <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>

        <div class="form-group">
            <label asp-for="ClienteId" class="form-label"></label>
            <select asp-for="ClienteId" asp-items="ViewBag.Clientes" class="form-control">
                <option value="">-- Seleccione un cliente --</option>
            </select>
            <span asp-validation-for="ClienteId" class="field-error"></span>
        </div>

        <div class="form-group">
            <label asp-for="MesaId" class="form-label"></label>
            <select asp-for="MesaId" asp-items="ViewBag.Mesas" class="form-control">
                <option value="">-- Seleccione una mesa --</option>
            </select>
            <span asp-validation-for="MesaId" class="field-error"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="FechaHora" class="form-label"></label>
                <input asp-for="FechaHora" type="datetime-local" class="form-control" />
                <span asp-validation-for="FechaHora" class="field-error"></span>
            </div>
            <div class="form-group">
                <label asp-for="NumeroPersonas" class="form-label"></label>
                <input asp-for="NumeroPersonas" type="number" min="1" max="20" class="form-control" />
                <span asp-validation-for="NumeroPersonas" class="field-error"></span>
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Notas" class="form-label"></label>
            <textarea asp-for="Notas" class="form-control" rows="3" placeholder="Alergias, ocasión especial, preferencias..."></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Crear Reserva</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>
