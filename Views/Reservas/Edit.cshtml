@model RestaurantBook.Models.Reserva
@{
    ViewData["Title"] = "Editar Reserva";
}

<div class="page-header">
    <h1>Editar Reserva #@Model.Id</h1>
    <a asp-action="Index" class="btn btn-secondary">← Volver</a>
</div>

<div class="form-container">
    <form asp-action="Edit">
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="FechaCreacion" />
        <div asp-validation-summary="ModelOnly" class="alert alert-error"></div>

        <div class="form-group">
            <label asp-for="ClienteId" class="form-label"></label>
            <select asp-for="ClienteId" asp-items="ViewBag.Clientes" class="form-control"></select>
        </div>

        <div class="form-group">
            <label asp-for="MesaId" class="form-label"></label>
            <select asp-for="MesaId" asp-items="ViewBag.Mesas" class="form-control"></select>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label asp-for="FechaHora" class="form-label"></label>
                <input asp-for="FechaHora" type="datetime-local" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="NumeroPersonas" class="form-label"></label>
                <input asp-for="NumeroPersonas" type="number" min="1" max="20" class="form-control" />
            </div>
        </div>

        <div class="form-group">
            <label asp-for="Estado" class="form-label"></label>
            <select asp-for="Estado" asp-items="ViewBag.Estados" class="form-control"></select>
        </div>

        <div class="form-group">
            <label asp-for="Notas" class="form-label"></label>
            <textarea asp-for="Notas" class="form-control" rows="3"></textarea>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">Guardar Cambios</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>
