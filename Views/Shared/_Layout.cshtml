<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RestaurantBook</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a class="nav-brand" asp-controller="Home" asp-action="Index">
                🍽 RestaurantBook
            </a>
            <div class="nav-links">
                <a asp-controller="Home" asp-action="Index">Inicio</a>
                <a asp-controller="Reservas" asp-action="Index">Reservas</a>
                <a asp-controller="Mesas" asp-action="Index">Mesas</a>
                <a asp-controller="Clientes" asp-action="Index">Clientes</a>
                <a asp-controller="Admin" asp-action="Index" class="btn-admin">Panel Admin</a>
            </div>
        </div>
    </nav>

    <main class="main-content">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success">
                ✓ @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-error">
                ✗ @TempData["Error"]
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer">
        <p>© @DateTime.Now.Year RestaurantBook — Sistema de Reservas</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
