@{
    ViewData["Title"] = "Panel de Administración";
}

<div class="page-header">
    <h1>Panel de Administración</h1>
    <span style="color:var(--text-muted);font-size:0.9rem">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
</div>

<div class="stats-grid">
    <div class="stat-card stat-blue">
        <div class="stat-number">@ViewBag.TotalReservas</div>
        <div class="stat-label">Total Reservas</div>
    </div>
    <div class="stat-card stat-green">
        <div class="stat-number">@ViewBag.ReservasHoy</div>
        <div class="stat-label">Reservas Hoy</div>
    </div>
    <div class="stat-card stat-yellow">
        <div class="stat-number">@ViewBag.ReservasPendientes</div>
        <div class="stat-label">Pendientes</div>
    </div>
    <div class="stat-card stat-teal">
        <div class="stat-number">@ViewBag.ReservasConfirmadas</div>
        <div class="stat-label">Confirmadas</div>
    </div>
    <div class="stat-card stat-purple">
        <div class="stat-number">@ViewBag.MesasDisponibles / @ViewBag.TotalMesas</div>
        <div class="stat-label">Mesas Disponibles</div>
    </div>
    <div class="stat-card stat-orange">
        <div class="stat-number">@ViewBag.TotalClientes</div>
        <div class="stat-label">Clientes Registrados</div>
    </div>
</div>

<div class="admin-section">
    <h2>Reservas Recientes</h2>
    <div class="table-container">
        <table class="table">
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Mesa</th>
                    <th>Fecha</th>
                    <th>Personas</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in ViewBag.ReservasRecientes)
                {
                    <tr>
                        <td>@r.Cliente?.Nombre</td>
                        <td>Mesa @r.Mesa?.Numero</td>
                        <td>@r.FechaHora.ToString("dd/MM/yyyy HH:mm")</td>
                        <td>@r.NumeroPersonas</td>
                        <td><span class="badge badge-@r.Estado.ToLower()">@r.Estado</span></td>
                        <td>
                            <a asp-controller="Reservas" asp-action="Edit" asp-route-id="@r.Id" class="btn-sm btn-warning">Editar</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <a asp-controller="Reservas" asp-action="Index" class="btn btn-secondary" style="margin-top:1rem">Ver todas las reservas →</a>
</div>

<div class="admin-links">
    <h2>Gestión Rápida</h2>
    <div class="action-grid">
        <a asp-controller="Reservas" asp-action="Create" class="action-card">
            <span class="action-icon">📅</span>
            <span>Nueva Reserva</span>
        </a>
        <a asp-controller="Mesas" asp-action="Create" class="action-card">
            <span class="action-icon">🪑</span>
            <span>Nueva Mesa</span>
        </a>
        <a asp-controller="Clientes" asp-action="Create" class="action-card">
            <span class="action-icon">👤</span>
            <span>Nuevo Cliente</span>
        </a>
        <a asp-controller="Reservas" asp-action="Index" class="action-card">
            <span class="action-icon">📋</span>
            <span>Ver Reservas</span>
        </a>
    </div>
</div>
